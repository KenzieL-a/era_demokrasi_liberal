@sukiman_connections1

@natsir_connections1
subtitle: -1 resources
choose-if: resources >= 1 and wilopo_dissent <= 20
unavailable-subtitle: [? if resources <= 1: Not enough resources. ?][? if wilopo_dissent >= 20: The party is unwilling. ?]
