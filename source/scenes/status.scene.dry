title: Status
new-page: true
is-special: true
on-arrival: {!
if (Q.unemployed) {
    Q.santri_2 = Q.unemployed.toFixed(1);
}
if (Q.inflation) {
    Q.inflation_2 = Q.inflation.toFixed(1);
}
Q.economic_growth_2 = '0';
if (Q.economic_growth) {
    Q.economic_growth_2 = Q.economic_growth.toFixed(1);
}
!}
on-display: {!
data = [
    {
        "id": "pki",
        "legend": "PKI",
        "name": "PKI",
        "seats": Math.round(Q.pki_r * Q.dprs_comp),
    },
    {
        "id": "psi",
        "legend": "PSI",
        "name": "PSI",
        "seats": Math.round(Q.psi_r * Q.dprs_comp),
    },
    {
        "id": "pni",
        "legend": "PNI",
        "name": "PNI",
        "seats": Math.round(Q.pni_r * Q.dprs_comp),
    },
    {
        "id": "other",
        "legend": "Other",
        "name": "Other",
        "seats": Math.round(Q.other_r * Q.dprs_comp),
    },
    {
        "id": "kristen",
        "legend": "Parkindo",
        "name": "parkindo",
        "seats": Math.round(Q.kristen_r * Q.dprs_comp),
    },
    {
        "id": "katolik",
        "legend": "Katolik",
        "name": "Katolik",
        "seats": Math.round(Q.katolik_r * Q.dprs_comp),
    },
        {
        "id": "psii",
        "legend": "PSII",
        "name": "PSII",
        "seats": Math.round(Q.psii_r * Q.dprs_comp),
    },
        {
        "id": "masyumi",
        "legend": "Masjumi",
        "name": "Masjumi",
        "seats": Math.round(Q.masyumi_r * Q.dprs_comp),
    },
];
if (window && d3) {
    var width = 500; 
    var height = 500;
    var screenWidth = document.getElementById('content').offsetWidth;
    if (screenWidth < width - 50) {
        width = screenWidth - 50; 
        height = width;
        document.getElementById("reichstag").style.height = screenWidth/2 + "px";
    } 

    var parliament = d3.parliament();
    parliament.width(width).height(height).innerRadiusCoef(0.4);
    parliament.enter.fromCenter(true).smallToBig(true);
    parliament.exit.toCenter(false).bigToSmall(true);
    d3.select("#reichstag").datum(data).call(parliament);
}
!}

= <span style="color: #990000;">**PNI**</span> Leadership

<div style="text-align: center;">Chairman: [+ pni_leader +]</div>
[? if pni_leader == "Sidik Djojosukarto": <div><img src="img/portraits/sidik.jpg" alt="Sidik Djojosukarto" style="width: 50%;display: block;margin: auto;margin-bottom: 5px;border: 5px solid var(--card-border-color);"></div> ?]

Deputy Chairman: 
<div style="text-align: left;margin-top: -15px;">[+ vice_chair +]</div>

General Secretary: 
<div style="text-align: left;margin-top: -15px;">[+ gensec +]</div>

Next Congress: [+ next_congress_month +] [+ next_congress_year +]

= Status

Resources available: [+ resources +]

Party dues: [+ dues +]

<span style="color: #990000;">**PNI**</span> position: [? if PNI_toleration : toleration ?][? if PNI_in_government : in government - ?][? if PNI_toleration == 0 and PNI_in_government == 0 and PNI_caretaker == 0 : opposition ?][? if PNI_caretaker : caretaker government ?]
[? if in_weimar_coalition and PNI_in_government: Weimar Coalition ?][? if in_grand_coalition and PNI_in_government: Grand Coalition ?][? if in_popular_front and PNI_in_government: Popular Front ?][? if in_left_front and PNI_in_government: Left Front ?][? if in_pni_majority and PNI_in_government: PNI majority ?][? if in_minority_government and PNI_in_government: minority government ?][? if in_emergency_government and PNI_in_government: emergency government ?]

[? if PNI_in_government and not in_pni_majority and not in_left_front : Coalition dissent: [+ coalition_dissent : coalition_dissent +] ?]

[? if PNI_in_government and (in_left_front or in_popular_front): PKI coalition dissent: [+ PKI_coalition_dissent : coalition_dissent +] ?]

= Internal Factions of the <span style="color: #990000;">**PNI**</span>

Internal dissent: [+ dissent_percent : dissent +]

{!<span class="tooltip-text" title="Wilopo's faction mostly consists of moderate, younger figures of the party.">Wilopo Group</span>!} (<span style="color: #ff6d50;">**Moderates**</span>) 
<div style="text-align: left;margin-top: -15px;">Strength: [+ wilopo_strength : strength +]</div>
<div style="text-align: left;margin-top: 0px;">Dissent: [+ wilopo_dissent : dissent +]</div>

{!<span class="tooltip-text" title="Sidik Djojosukarto and his clique pushes the party to a pro-labor and socialist stance.">Sidik Group</span>!} (<span style="color: #e90000;">**Leftists**</span>) 
<div style="text-align: left;margin-top: -15px;">Strength: [+ sidik_strength : strength +]</div>
<div style="text-align: left;margin-top: 0px;">Dissent: [+ sidik_dissent : dissent +]</div>

{!<span class="tooltip-text" title="The Sartono-Suwirjo group are mostly administrators and bureaucrats who are more radical in their nationalism.">Sartono-Suwirjo Group</span>!} (<span style="color: #7c0000;">**Radicals**</span>) 
<div style="text-align: left;margin-top: -15px;">Strength: [+ partindo_strength : strength +]</div>
<div style="text-align: left;margin-top: 0px;">Dissent: [+ partindo_dissent : dissent +]</div>

= Economics

Inflation: [+ inflation_2 +]%

[? if black_thursday_seen = 1 : Unemployment: [+ santri_2 +]% ?]

Economic growth: [+ economic_growth_2 +]%

