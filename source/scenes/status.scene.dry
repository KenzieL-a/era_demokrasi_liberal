=Party Leadership

<img src="img/icons/PNI.png" style="height: 10px;"> {!<span class="tooltip-text" title="Indonesian Nationalist Party" style="color: #990000;"><strong>PNI</strong></span>!}: [+ pni_leader +] (Marhaenism)

<img src="img/icons/masjumi.png" style="height: 10px;"> {!<span class="tooltip-text" title="Council of Indonesian Muslim Associations Party" style="color: #000000;"><strong>Masjumi</strong></span>!}: [+ masyumi_leader +] ([+ masyumi_ideology1 +])

<img src="img/icons/PSI.png" style="height: 10px;"> {!<span class="tooltip-text" title="Indonesian Socialist Party" style="color: #FF6666;"><strong>PSI</strong></span>!}: Sutan Sjahrir (Popular Socialism)

<img src="img/icons/PSII.png" style="height: 10px;"> {!<span class="tooltip-text" title="Indonesian Islamic Union Party" style="color: #003319;"><strong>PSII</strong></span>!}: Anwar Tjokroaminoto (Islamic Democracy)

<img src="img/icons/PKI.png" style="height: 10px;"> {!<span class="tooltip-text" title="Indonesian Communist Party" style="color: #c00000;"><strong>PKI</strong></span>!}: [+ pki_leader +] ([? if pki_leader == "Alimin": Marxism-Leninism?][? if pki_leader == "D.N. Aidit": Maoism?])

<img src="img/icons/kristen.png" style="height: 10px;"> {!<span class="tooltip-text" title="Indonesian Christian Party (Protestant)" style="color: #66B2FF;"><strong>Parkindo</strong></span>!}: Johannes Leimena (Christian Democracy)

<img src="img/icons/katolik.png" style="height: 10px;"> {!<span class="tooltip-text" title="Catholic Party" style="color: #330000;"><strong>Katolik</strong></span>!}: I. J. Kasimo (Catholic Democracy)

{!<span class="tooltip-text" title="Greater Indonesia Union Party" style="color: #894400;"><strong>PIR</strong></span>!}: Wongsonegoro (Nationalism)

{!<span class="tooltip-text" title="National People's Party" style="color: #545454;"><strong>PRN</strong></span>!}: Djody Gondokusumo (Nationalism)

{!<span class="tooltip-text" title="Labour Party" style="color: #ff0000;"><strong>Buruh</strong></span>!}: Iskandar Tedjakusuma (Labourism)

